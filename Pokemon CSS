* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: Arial;
    background: #f0f8ff;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

header {
    background: #ffcb05;
    padding: 1rem;
    text-align: center;
    color: #3b4cca;
}

main {
    flex: 1;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

/* SEARCH */
.search-section {
    text-align: center;
}

#pokemonInput {
    padding: 0.5rem;
    width: 200px;
}

button {
    padding: 0.5rem;
    cursor: pointer;
    border: none;
}

/* AUTOCOMPLETE */
.suggestions-box {
    max-width: 200px;
    margin: auto;
    background: white;
    border: 1px solid #ccc;
}

.suggestions-box div {
    padding: 0.4rem;
    cursor: pointer;
}

.suggestions-box div:hover {
    background: #eee;
}

/* FILTERS */
.filter-section {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.filter-section input,
.filter-section select {
    padding: 0.4rem;
}

/* DISPLAY */
.pokemon-display {
    display: flex;
    justify-content: center;
}

.pokemon-card {
    background: white;
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    width: 200px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.pokemon-card img {
    width: 120px;
}

/* FAVORITES */
.favorites-section {
    text-align: center;
}

#favoritesList {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
}

#favoritesList li {
    background: white;
    border: 1px solid #ccc;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
}

/* BUTTON COLORS */
.add-fav {
    background: red;
    color: white;
}

.remove-fav {
    background: green;
    color: white;
}
