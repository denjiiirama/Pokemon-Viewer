<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokémon Viewer</title>
    <link rel="stylesheet" href="pokemonstyle.css">
</head>
<body>

<header>
    <h1>Pokémon Viewer 🐱‍👤</h1>
</header>

<main>

    <!-- SEARCH -->
    <section class="search-section">
        <form id="pokemonForm">
            <input type="text" id="pokemonInput" placeholder="Search Pokémon..." required>
            <button type="submit">Search</button>
        </form>

        <!-- Autocomplete -->
        <div id="suggestions" class="suggestions-box"></div>
    </section>

   <!-- FILTERS -->
<section class="filter-section">
    <select id="typeFilter">
        <option value="">All Types</option>
        <option value="normal">Normal</option>
        <option value="fighting">Fighting</option>
        <option value="flying">Flying</option>
        <option value="poison">Poison</option>
        <option value="ground">Ground</option>
        <option value="rock">Rock</option>
        <option value="bug">Bug</option>
        <option value="ghost">Ghost</option>
        <option value="steel">Steel</option>
        <option value="fire">Fire</option>
        <option value="water">Water</option>
        <option value="grass">Grass</option>
        <option value="electric">Electric</option>
        <option value="psychic">Psychic</option>
        <option value="ice">Ice</option>
        <option value="dragon">Dragon</option>
        <option value="dark">Dark</option>
        <option value="fairy">Fairy</option>
    </select>

    <input type="number" id="minHP" placeholder="Min HP">
    <input type="number" id="minAttack" placeholder="Min Attack">
</section>

    <!-- DISPLAY -->
    <section id="pokemonDisplay" class="pokemon-display">
        <!-- Multiple Pokémon cards will be added here -->
    </section>

    <!-- FAVORITES -->
    <section class="favorites-section">
        <h2>Favorites ❤️</h2>
        <ul id="favoritesList"></ul>
    </section>

</main>

<footer>
    <p>Data from <a href="https://pokeapi.co/" target="_blank">PokéAPI</a></p>
</footer>

<script src="pokemonscript.js"></script>
</body>
</html>
