<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokémon Viewer</title>
    <link rel="stylesheet" href="pokemonstyle.css">
</head>
<body>

<header>
    <h1>Pokémon Viewer 🐱‍👤</h1>
</header>

<main>

    <!-- SEARCH -->
    <section class="search-section">
        <form id="pokemonForm">
            <input type="text" id="pokemonInput" placeholder="Search Pokémon..." required>
            <button type="submit">Search</button>
        </form>

        <!-- Autocomplete -->
        <div id="suggestions" class="suggestions-box"></div>
    </section>

    <!-- FILTERS -->
    <section class="filter-section">
        <select id="typeFilter">
            <option value="">All Types</option>
            <option value="fire">Fire</option>
            <option value="water">Water</option>
            <option value="grass">Grass</option>
            <option value="electric">Electric</option>
            <option value="psychic">Psychic</option>
            <option value="ice">Ice</option>
            <option value="dragon">Dragon</option>
        </select>

        <input type="number" id="minHP" placeholder="Min HP">
        <input type="number" id="minAttack" placeholder="Min Attack">

        <button id="randomBtn">🎲 Random</button>
    </section>

    <!-- DISPLAY -->
    <section id="pokemonDisplay" class="pokemon-display"></section>

    <!-- FAVORITES -->
    <section class="favorites-section">
        <h2>Favorites ❤️</h2>
        <ul id="favoritesList"></ul>
    </section>

</main>

<footer>
    <p>Data from <a href="https://pokeapi.co/" target="_blank">PokéAPI</a></p>
</footer>

<script src="pokemonscript.js"></script>
</body>
</html>
