<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokémon Viewer</title>
    <link rel="stylesheet" href="pokemonstyle.css">
</head>
<body>
    <header>
        <h1>Pokémon Viewer</h1>
    </header>

    <main>
        <!-- Search Form -->
        <section class="search-section">
            <form id="pokemonForm">
                <input type="text" id="pokemonInput" placeholder="Enter Pokémon name..." required>
                <button type="submit">Search</button>
            </form>
        </section>

        <!-- Pokémon Display -->
        <section id="pokemonDisplay" class="pokemon-display">
            <!-- Pokémon info will be dynamically added here -->
        </section>

        <!-- Favorites Section -->
        <section class="favorites-section">
            <h2>Favorites ❤️</h2>
            <ul id="favoritesList">
                <!-- Favorite Pokémon will be listed here -->
            </ul>
        </section>
    </main>

    <footer>
        <p>Data fetched from <a href="https://pokeapi.co/" target="_blank">PokéAPI</a></p>
    </footer>

    <script src="pokemonscript.js"></script>
</body>
</html>
