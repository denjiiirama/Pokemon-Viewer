const form = document.getElementById('pokemonForm');
const input = document.getElementById('pokemonInput');
const display = document.getElementById('pokemonDisplay');
const favoritesList = document.getElementById('favoritesList');

const suggestionsBox = document.getElementById('suggestions');
const typeFilter = document.getElementById('typeFilter');
const minHP = document.getElementById('minHP');
const minAttack = document.getElementById('minAttack');

let favorites = [];
let allPokemon = [];

// LOAD ALL POKEMON NAMES
async function loadList() {
    const res = await fetch('https://pokeapi.co/api/v2/pokemon?limit=1000');
    const data = await res.json();
    allPokemon = data.results.map(p => p.name);
}
loadList();

// AUTOCOMPLETE
input.addEventListener('input', () => {
    const value = input.value.toLowerCase();
    suggestionsBox.innerHTML = '';

    if (!value) return;

    const matches = allPokemon.filter(p => p.startsWith(value)).slice(0, 5);

    matches.forEach(name => {
        const div = document.createElement('div');
        div.textContent = name;

        div.onclick = () => {
            input.value = name;
            suggestionsBox.innerHTML = '';
            fetchPokemon(name);
        };

        suggestionsBox.appendChild(div);
    });
});

// FETCH POKEMON DATA
async function fetchPokemon(identifier) {
    try {
        const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${identifier}`);
        if (!res.ok) throw new Error("Not found");
        const data = await res.json();
        showPokemon(data);
    } catch {
        const msg = document.createElement('p');
        msg.textContent = "Pokémon not found";
        display.appendChild(msg);
    }
}

// DISPLAY POKEMON CARD
function showPokemon(pokemon) {
    const hp = pokemon.stats.find(stat => stat.stat.name === "hp").base_stat;
    const attack = pokemon.stats.find(stat => stat.stat.name === "attack").base_stat;

    // FILTERS
    if (
        (typeFilter.value && !pokemon.types.some(t => t.type.name === typeFilter.value)) ||
        (minHP.value && hp < minHP.value) ||
        (minAttack.value && attack < minAttack.value)
    ) {
        const msg = document.createElement('p');
        msg.textContent = "No match";
        display.appendChild(msg);
        return;
    }

    const isFav = favorites.includes(pokemon.name);

    // Create card element
    const card = document.createElement('div');
    card.className = "pokemon-card";
    card.innerHTML = `
        <h3>${pokemon.name.toUpperCase()}</h3>
        <img src="${pokemon.sprites.front_default}" alt="${pokemon.name}">
        <p>Type: ${pokemon.types.map(t => t.type.name).join(', ')}</p>
        <p>HP: ${hp}</p>
        <p>Attack: ${attack}</p>
        <div class="card-buttons">
            <button class="${isFav ? 'remove-fav' : 'add-fav'}">
                ${isFav ? 'Remove 💚' : 'Add ❤️'}
            </button>
            <button class="remove-card">Remove ❌</button>
        </div>
    `;

    // Favorite button logic
    const favBtn = card.querySelector('.add-fav, .remove-fav');
    favBtn.onclick = () => {
        if (isFav) {
            favorites = favorites.filter(f => f !== pokemon.name);
        } else {
            favorites.push(pokemon.name);
        }
        updateFavorites();
        // Re-render this card to update button state
        card.remove();
        showPokemon(pokemon);
    };

    // Remove card button logic
    const removeBtn = card.querySelector('.remove-card');
    removeBtn.onclick = () => {
        card.remove();
    };

    // Append card instead of replacing
    display.appendChild(card);
}


// FAVORITES LIST
function updateFavorites() {
    favoritesList.innerHTML = '';

    favorites.forEach(fav => {
        const li = document.createElement('li');
        li.textContent = fav.toUpperCase();
        li.onclick = () => fetchPokemon(fav);
        favoritesList.appendChild(li);
    });
}

// FORM SUBMIT
form.addEventListener('submit', e => {
    e.preventDefault();
    fetchPokemon(input.value.toLowerCase());
    input.value = '';
    suggestionsBox.innerHTML = '';
});
