const pokemonForm = document.getElementById('pokemonForm');
const pokemonInput = document.getElementById('pokemonInput');
const pokemonDisplay = document.getElementById('pokemonDisplay');
const favoritesList = document.getElementById('favoritesList');

let favorites = [];

// Fetch Pokémon data
async function fetchPokemon(name) {
    try {
        const response = await fetch(`https://pokeapi.co/api/v2/pokemon/${name.toLowerCase()}`);
        if (!response.ok) throw new Error('Pokémon not found');
        const data = await response.json();
        displayPokemon(data);
    } catch (error) {
        alert(error.message);
    }
}

// Display Pokémon card
function displayPokemon(pokemon) {
    const isFav = favorites.includes(pokemon.name);
    pokemonDisplay.innerHTML = `
        <div class="pokemon-card">
            <h3>${pokemon.name.toUpperCase()}</h3>
            <img src="${pokemon.sprites.front_default}" alt="${pokemon.name}">
            <p>Type: ${pokemon.types.map(t => t.type.name).join(', ')}</p>
            <p>HP: ${pokemon.stats[0].base_stat}</p>
            <p>Attack: ${pokemon.stats[1].base_stat}</p>
            <button class="${isFav ? 'remove-fav' : 'add-fav'}" id="favBtn">
                ${isFav ? 'Remove from Favorites 💚' : 'Add to Favorites ❤️'}
            </button>
        </div>
    `;

    // Add event listener for the button
    const favBtn = document.getElementById('favBtn');
    favBtn.addEventListener('click', () => {
        if (favorites.includes(pokemon.name)) {
            removeFavorite(pokemon.name);
            favBtn.textContent = 'Add to Favorites ❤️';
            favBtn.classList.remove('remove-fav');
            favBtn.classList.add('add-fav');
        } else {
            addFavorite(pokemon.name);
            favBtn.textContent = 'Remove from Favorites 💚';
            favBtn.classList.remove('add-fav');
            favBtn.classList.add('remove-fav');
        }
    });
}

// Add to favorites
function addFavorite(name) {
    if (!favorites.includes(name)) {
        favorites.push(name);
        updateFavorites();
    }
}

// Remove from favorites
function removeFavorite(name) {
    favorites = favorites.filter(fav => fav !== name);
    updateFavorites();
}

// Update favorites list in DOM
function updateFavorites() {
    favoritesList.innerHTML = '';
    favorites.forEach(fav => {
        const li = document.createElement('li');
        li.textContent = fav.toUpperCase();
        // Clicking a favorite shows its card instead of removing immediately
        li.addEventListener('click', () => fetchPokemon(fav));
        favoritesList.appendChild(li);
    });
}

// Event listener for form submit
pokemonForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const pokemonName = pokemonInput.value.trim();
    if (pokemonName) fetchPokemon(pokemonName);
    pokemonInput.value = '';
});
